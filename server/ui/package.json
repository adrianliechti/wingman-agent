{
	"name": "ui",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "oxlint",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"preview": "vite preview",
		"test:e2e": "npm run test:cli && npm run test:web",
		"test:cli": "go test -tags=e2e -run TestTUIE2E -count=1 -v ../../pkg/tui/code",
		"test:web": "go test -tags=e2e -run TestWebUIE2E -count=1 -v .."
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"@streamdown/code": "^1.1.1",
		"@streamdown/math": "^1.0.2",
		"@streamdown/mermaid": "^1.0.2",
		"@tailwindcss/vite": "^4.3.3",
		"devicon": "^2.17.0",
		"lucide-react": "^1.25.0",
		"monaco-editor": "^0.55.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-markdown": "^10.1.0",
		"react-resizable-panels": "^4.12.2",
		"remark-gfm": "^4.0.1",
		"streamdown": "^2.5.0",
		"tailwindcss": "^4.2.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/node": "^24.13.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"typescript": "^7.0.2",
		"vite": "^8.1.5"
	}
}
